# Optional variable for docker-compose.yml.
# Copy this file to ".env" in the same folder if you need to override it.
#
# The Hugging Face token does NOT go here: use Docker secrets instead.
# See secrets/README.md to get and set up your own read-only token.

# NER model to load (default: anvorja/panoncology-biomedical-ner-sp).
# MODEL_PATH=anvorja/panoncology-biomedical-ner-sp
